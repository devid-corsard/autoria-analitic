api_key=autoria_api_key
DB_HOST=localhost
DB_PORT=5432
DB_USER=your_postgres_user
DB_PASSWORD=your_postgres_password
DB_NAME=your_database_name

# For Superset / Metabase (when adding the database in the UI): use host "postgres",
# port 5432, and the same DB_USER, DB_PASSWORD, DB_NAME. The dashboard compose
# uses frogfort-network so "postgres" resolves to the Postgres container.
# Superset: http://localhost:8088 — default login admin / admin.
